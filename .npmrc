# SEC CN-012 (Cyber Neo) — pinnear el registro evita dependency confusion:
# que un paquete público que squattee @vim/* sea resuelto desde otro registro.
registry=https://registry.npmjs.org/
@vim:registry=https://registry.npmjs.org/

# Instalaciones reproducibles: falla si el lockfile no coincide (CI/prod).
# (En local, `pnpm install` normal sigue funcionando; esto endurece CI.)
auto-install-peers=true
strict-peer-dependencies=false

# Bloquea scripts de build de dependencias transitivas salvo allow-list (pnpm v9+).
# Mantener el árbol sin ejecución de código arbitrario en install.
