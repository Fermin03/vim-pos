{
  "name": "vim-pos-desktop",
  "version": "0.3.3",
  "private": true,
  "type": "module",
  "description": "Fase 1 — VIM POS de escritorio local-first: Postgres embebido + PostgREST + gateway compatible con Supabase + auth PIN local, empaquetado en Electron.",
  "author": "VIM Marketing <ferminvillalobos16@gmail.com>",
  "main": "src/main.mjs",
  "scripts": {
    "verify": "node src/verify-e2e.mjs",
    "verify:sync": "node src/verify-sync.mjs",
    "verify:push": "node src/verify-push.mjs",
    "verify:dia": "node src/verify-dia.mjs",
    "verify:robustez": "node src/verify-robustez.mjs",
    "verify:cloud": "node src/verify-cloud.mjs",
    "verify:hub": "node src/verify-hub.mjs",
    "backend": "node src/backend.mjs",
    "build:ui": "node scripts/build-ui.mjs",
    "build:kds-ui": "node scripts/build-kds-ui.mjs",
    "start": "electron .",
    "start:cocina": "electron . --role=cocina",
    "backup": "node scripts/backup-cli.mjs",
    "restore": "node scripts/restore.mjs",
    "release-manifest": "node scripts/release-manifest.mjs",
    "verify:robustez3": "node src/verify-robustez3.mjs",
    "verify:updater": "node src/verify-updater.mjs",
    "dist": "npm run build:ui && npm run build:kds-ui && node scripts/dist.mjs"
  },
  "dependencies": {
    "embedded-postgres": "17.10.0-beta.17",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.13.1"
  },
  "devDependencies": {
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.vimpos.desktop",
    "productName": "VIM POS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "asar": false,
    "extraResources": [
      {
        "from": "../supabase/migrations",
        "to": "migrations"
      },
      {
        "from": "../supabase/seed.sql",
        "to": "seed.sql"
      },
      {
        "from": "sql",
        "to": "sql"
      },
      {
        "from": "bin/postgrest.exe",
        "to": "bin/postgrest.exe"
      },
      {
        "from": "node_modules/@embedded-postgres/windows-x64/native/bin",
        "to": "pg-bin"
      },
      {
        "from": "pos-ui",
        "to": "pos-ui"
      },
      {
        "from": "kds-ui",
        "to": "kds-ui"
      },
      {
        "from": "build/tray.png",
        "to": "tray.png"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "include": "build/installer.nsh"
    }
  }
}
