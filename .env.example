# ============================================================================
# VIM POS — variables de entorno. Copia este archivo a .env.local y rellena.
# .env.local está en .gitignore: los SECRETOS nunca se commitean ni se comparten.
# ============================================================================

# ---- PÚBLICAS (seguras en cliente: apps pos / admin / platform) ----
# Las da el dashboard de Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon / publishable key>"

# ---- SECRETAS (SOLO server-side: platform + Edge Functions) ----
# NUNCA en apps/pos ni apps/admin de cliente. NUNCA en git.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="<anon key>"        # Edge Functions: gateway + clientes con el JWT del llamante
SUPABASE_SERVICE_ROLE_KEY=""          # ignora RLS — máximo cuidado (solo platform + functions)
SUPABASE_JWT_SECRET=""                # firma los tokens de empleado (pin-login)

# ---- Edge Functions: secretos propios (no admiten prefijo SUPABASE_) ----
# Local: supabase/functions/.env  ·  Cloud: `supabase secrets set NOMBRE=valor`
VIM_JWT_SECRET=""                     # = SUPABASE_JWT_SECRET; pin-login acuña el JWT de empleado con él

# ---- CFDI / PAC (F8) — necesario en GO-LIVE para timbrar de verdad ----
# Si FACTURAPI_API_KEY está presente, timbrar-cfdi usa Facturapi (@sin-verificar);
# si no, usa el PAC MOCK (NO genera CFDI válidos). Ver supabase/functions/_shared/pac/.
FACTURAPI_API_KEY=""                  # API key del PAC (Facturapi.io). Subir el CSD al emisor antes.
# Alternativa si se cambia de PAC (esquema original mencionaba Facturama):
# FACTURAMA_API_USER=""
# FACTURAMA_API_PASSWORD=""

# ---- Plataforma de provisioning (F10) ----
# Secreto compartido que protege la Edge Function provisionar-tenant y las rutas /api/* de
# apps/platform. Genera uno fuerte (p.ej. `openssl rand -hex 32`). Solo lo conoce VIM.
# Fail-closed: si falta, el provisioning queda deshabilitado (503).
PLATFORM_PROVISION_KEY=""

# ---- CORS de las Edge Functions (SEC CN-004) ----
# Lista separada por comas de orígenes permitidos en producción. Vacío => CORS '*' (dev).
# En prod fijarlo (vía `supabase secrets set`):
# VIM_CORS_ORIGINS="https://pos.vimpos.mx,https://admin.vimpos.mx,https://app.vimpos.mx"
VIM_CORS_ORIGINS=""

# ---- Para vincular el CLI al proyecto cloud (no es runtime) ----
# SUPABASE_PROJECT_REF="<project-ref>"
# DB password: se usa en `supabase link`, no se guarda aquí.
