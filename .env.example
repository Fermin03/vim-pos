# ============================================================================
# VIM POS — variables de entorno. Copia este archivo a .env.local y rellena.
# .env.local está en .gitignore: los SECRETOS nunca se commitean ni se comparten.
# ============================================================================

# ---- PÚBLICAS (seguras en cliente: apps pos / admin / platform) ----
# Las da el dashboard de Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon / publishable key>"

# ---- SECRETAS (SOLO server-side: platform + Edge Functions) ----
# NUNCA en apps/pos ni apps/admin de cliente. NUNCA en git.
SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_SERVICE_ROLE_KEY=""   # ignora RLS — máximo cuidado
SUPABASE_JWT_SECRET=""               # firma los tokens de empleado (pin-login)

# ---- Facturama (Edge Functions CFDI) — necesario en GO-LIVE, no antes ----
FACTURAMA_API_USER=""
FACTURAMA_API_PASSWORD=""

# ---- Para vincular el CLI al proyecto cloud (no es runtime) ----
# SUPABASE_PROJECT_REF="<project-ref>"
# DB password: se usa en `supabase link`, no se guarda aquí.
